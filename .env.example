# ============================================================
# Variables de entorno requeridas para producción
# Copia este archivo a .env.local y rellena los valores reales
# ============================================================

# Secreto para firmar los tokens de sesión (OBLIGATORIO en producción)
# Genera uno seguro con: openssl rand -hex 64
CRM_AUTH_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio

# Entorno (development | production)
NODE_ENV=production
